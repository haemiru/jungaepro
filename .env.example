VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_DEV_TENANT_SLUG=demo

# Kakao Map JavaScript key (https://developers.kakao.com)
VITE_KAKAO_MAP_KEY=your-kakao-javascript-key
# Kakao REST API key — used by Vite dev proxy for geocoding (NOT exposed to client)
KAKAO_REST_KEY=your-kakao-rest-api-key

# Gemini API key — used by Vite dev proxy (NOT exposed to client bundle)
# In production, set as Supabase secret: supabase secrets set GEMINI_API_KEY=...
GEMINI_API_KEY=your-gemini-api-key

# 국토교통부 실거래가 API key (https://www.data.go.kr)
# In production, set as Supabase secret: supabase secrets set MOLIT_API_KEY=...
MOLIT_API_KEY=your-molit-api-key

# 네이버 검색 API (https://developers.naver.com)
# In production, set as Supabase secrets
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ── 토스페이먼츠 정기결제 (https://developers.tosspayments.com) ──
# 클라이언트 키(공개) — 결제창 로드. 테스트: test_ck_..., 라이브: live_ck_...
VITE_TOSS_CLIENT_KEY=test_ck_your-client-key
# 시크릿 키 — 빌링키 발급/자동결제 승인. 절대 클라이언트 노출 금지.
# dev: 아래 .env 에 두면 Vite 프록시가 사용 / prod: supabase secrets set TOSS_SECRET_KEY=...
TOSS_SECRET_KEY=test_sk_your-secret-key
# 자동갱신 cron 보호용 공유 시크릿 (pg_cron → billing-cron 호출 헤더)
# prod: supabase secrets set CRON_SECRET=...
CRON_SECRET=your-random-cron-secret
# Supabase 서비스 롤 키 — dev 결제 프록시가 서버측 DB 쓰기에 사용 (NOT exposed to client)
# prod 에서는 Edge Function 이 런타임에 자동 주입받으므로 불필요.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
